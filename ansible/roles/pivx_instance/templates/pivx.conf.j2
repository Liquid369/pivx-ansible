# pivx.conf — {{ instance.name }}
# Generated by Ansible. Do NOT edit manually — changes will be overwritten on next deploy.
#
# Host:           {{ inventory_hostname }}
# Provider:       {{ provider }}
# Role:           {{ instance.role }}
# Protocol:       {{ instance.protocol_class }}
# Cohort:         {{ instance.cohort }}
# Lifecycle:      {{ lifecycle_phase }}
#
# To regenerate: make deploy-pivx LIMIT={{ inventory_hostname }}

# =============================================================================
# NETWORK SELECTION
# =============================================================================
testnet=1

# IMPORTANT: everything below lives in the [test] section. This build gates
# addnode/connect/port/bind/rpcport/rpcbind/wallet to the active network
# section (util/system.cpp m_network_only_args) — values for those keys in
# the global section are silently IGNORED when testnet=1.
[test]

# =============================================================================
# GENERAL
# =============================================================================
maxconnections={{ 256 if instance.role == 'seeder' else (pivx_maxconnections | default(125)) }}
printtoconsole={{ pivx_printtoconsole | default(1) }}

# Sapling zk-SNARK parameters. Kept outside /home because the systemd unit
# uses ProtectHome=true.
paramsdir={{ pivx_params_dir }}

{% if instance.protocol_class == 'ipv4' %}
# --- IPv4 mode ---
listen=1
bind={{ instance.bind_addr }}
externalip={{ instance.external_ip }}
{% elif instance.protocol_class == 'ipv6' %}
# --- IPv6 mode ---
listen=1
bind={{ instance.bind_addr }}
externalip={{ instance.external_ip }}
onlynet=ipv6
{% elif instance.protocol_class == 'tor' %}
# --- Tor-only mode ---
# Binds on loopback; all traffic routed through Tor SOCKS proxy.
# External address is the hidden service .onion from Tor.
listen=1
bind=127.0.0.1
proxy=127.0.0.1:{{ tor_socks_port | default(9050) }}
onlynet=onion
{% if instance.onion_address | default('') != '' %}
externalip={{ instance.onion_address }}
{% else %}
# externalip= not set — run `make deploy-tor` first and fill onion_address in host_vars
{% endif %}
{% endif %}

port={{ instance.p2p_port }}

# =============================================================================
# SEED / ADDNODE
# Connections to the known seed nodes.
# Replace with real addresses once seeds are up.
# =============================================================================
{% for seed in pivx_seed_nodes | default([]) %}
addnode={{ seed }}
{% endfor %}

# =============================================================================
# RPC
# Bound to localhost only. Remote monitoring uses SSH tunnel if needed.
# =============================================================================
server=1
rpcuser={{ instance.rpc_user }}
rpcpassword={{ instance.rpc_password }}
rpcport={{ instance.rpc_port }}
rpcbind=127.0.0.1
rpcallowip=127.0.0.1

# =============================================================================
# DATA / LOGGING
# =============================================================================
datadir={{ instance.datadir }}
debuglogfile={{ instance.logdir }}/debug.log

{% for cat in pivx_debug_categories | default(['net']) %}
debug={{ cat }}
{% endfor %}

# =============================================================================
# LIFECYCLE PHASE: {{ lifecycle_phase }}
# =============================================================================

{% if (instance.mining_enabled | default(false)) and lifecycle_phase == 'bootstrap_mining' %}
# --- Phase 2: Bootstrap Mining ---
# This instance mines PoW blocks to bootstrap the chain. Rewards are paid to
# this node's own wallet (there is no miningaddress option in this build —
# GenerateBitcoins mines to vpwallets[0]). PoW ends at the UPGRADE_POS
# activation height ({{ mining_phase_target_height | default(201) }} on testnet).
# Mining is disabled when `make stop-bootstrap-mining` is run (Phase 3).
gen=1
genproclimit={{ bootstrap_mining_threads | default(1) }}
{% else %}
# Mining disabled (lifecycle_phase={{ lifecycle_phase }} or mining_enabled=false)
gen=0
{% endif %}

{% if instance.staking_enabled | default(false) %}
# --- Phase 3+: Staking enabled ---
staking=1
{% else %}
staking=0
{% endif %}

{% if (instance.masternode_enabled | default(false)) and instance.role == 'masternode' %}
# --- Phase 4: Masternode enabled (deterministic) ---
masternode=1
{% if instance.bls_operator_key | default('') not in ['', 'REPLACE_ME'] %}
mnoperatorprivatekey={{ instance.bls_operator_key }}
{% else %}
# mnoperatorprivatekey= not set — generate with `pivx-cli generateblskeypair`
# and fill bls_operator_key in host_vars!
{% endif %}
{% endif %}

# =============================================================================
# ROLE-SPECIFIC SETTINGS
# =============================================================================
{% if instance.role == 'seeder' %}
# Seeder node — high connection count (maxconnections set above),
# no masternode behavior.
{% elif instance.role == 'observer' %}
# Observer node — reads blockchain, does not participate in consensus.
# (No addressindex option exists in this build; txindex only.)
txindex=1
{% endif %}

# =============================================================================
# INSTANCE-SPECIFIC EXTRAS
# These lines come from instance.extra_conf in host_vars.
# =============================================================================
{% for line in instance.extra_conf | default([], true) %}
{{ line }}
{% endfor %}
