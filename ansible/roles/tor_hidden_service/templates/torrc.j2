# /etc/tor/torrc
# Generated by Ansible for host: {{ inventory_hostname }}
# Configures hidden services for Tor-cohort PIVX instances.

SocksPort 9050
SocksPolicy accept 127.0.0.1
SocksPolicy reject *

# Log to journal
Log notice syslog

# Hidden services — one per Tor masternode instance
{% for inst in pivx_instances | selectattr('protocol_class', 'equalto', 'tor') | list %}
# {{ inst.name }}
HiddenServiceDir {{ inst.onion_service_dir }}
HiddenServicePort {{ inst.p2p_port }} 127.0.0.1:{{ inst.p2p_port }}
HiddenServiceVersion 3
{% endfor %}
