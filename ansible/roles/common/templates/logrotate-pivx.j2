# /etc/logrotate.d/pivx — Generated by Ansible

/var/log/pivx/*/*.log {
    daily
    missingok
    rotate 14
    compress
    delaycompress
    notifempty
    sharedscripts
    postrotate
        # Signal pivxd to reopen log files if running
        for pidfile in /var/lib/pivx/*/pivxd.pid; do
            [ -f "$pidfile" ] && kill -HUP "$(cat $pidfile)" 2>/dev/null || true
        done
    endscript
}
