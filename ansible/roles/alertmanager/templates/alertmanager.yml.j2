# /etc/alertmanager/alertmanager.yml
# Generated by Ansible

global:
  resolve_timeout: 5m
  slack_api_url: "{{ vault_alertmanager_slack_webhook }}"

route:
  group_by: ["alertname", "chain", "instance", "cohort"]
  group_wait:      30s
  group_interval:  5m
  repeat_interval: 4h
  receiver: slack-default

  routes:
    # Critical PIVX quorum alerts page immediately
    - match:
        severity: critical
      receiver: slack-critical
      continue: true

receivers:
  - name: slack-default
    slack_configs:
      - channel: "#tn6-alerts"
        send_resolved: true
        title: >-
          [{{ '{{' }} .Status | toUpper {{ '}}' }}][{{ '{{' }} .CommonLabels.chain {{ '}}' }}]
          {{ '{{' }} .CommonAnnotations.summary {{ '}}' }}
        text: >-
          {{ '{{' }} range .Alerts {{ '}}' }}
          *Alert:* {{ '{{' }} .Annotations.summary {{ '}}' }}
          *Host:* {{ '{{' }} .Labels.instance {{ '}}' }}
          *Cohort:* {{ '{{' }} .Labels.cohort {{ '}}' }}
          *Provider:* {{ '{{' }} .Labels.provider {{ '}}' }}
          {{ '{{' }} end {{ '}}' }}

  - name: slack-critical
    slack_configs:
      - channel: "#tn6-critical"
        send_resolved: true
        title: >-
          🚨 CRITICAL — {{ '{{' }} .CommonAnnotations.summary {{ '}}' }}

inhibit_rules:
  - source_match:
      severity: critical
    target_match:
      severity: warning
    equal: ["alertname", "instance"]
