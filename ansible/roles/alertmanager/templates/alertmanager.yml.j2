# /etc/alertmanager/alertmanager.yml
# Generated by Ansible
{#
  Notification targets: Discord and/or Telegram (no Slack — team preference).
  - Discord:  set alertmanager_discord_webhook_url (or vault_alertmanager_discord_webhook)
  - Telegram: set alertmanager_telegram_bot_token + alertmanager_telegram_chat_id
              (or vault_alertmanager_telegram_bot_token / _chat_id)
  Any unconfigured channel is simply omitted. With neither configured the
  receivers are no-ops and Alertmanager still starts cleanly.
#}
{% set _discord_webhook = vault_alertmanager_discord_webhook | default(alertmanager_discord_webhook_url | default('')) %}
{% set _discord_enabled = _discord_webhook not in ['', 'REPLACE_ME'] %}
{% set _tg_token = vault_alertmanager_telegram_bot_token | default(alertmanager_telegram_bot_token | default('')) %}
{% set _tg_chat_id = vault_alertmanager_telegram_chat_id | default(alertmanager_telegram_chat_id | default('')) %}
{% set _telegram_enabled = (_tg_token not in ['', 'REPLACE_ME']) and (_tg_chat_id | string not in ['', 'REPLACE_ME']) %}

global:
  resolve_timeout: 5m

route:
  group_by: ["alertname", "chain", "instance", "cohort"]
  group_wait:      30s
  group_interval:  5m
  repeat_interval: {{ alertmanager_repeat_interval | default('4h') }}
  receiver: default

  routes:
    # Critical PIVX quorum alerts page immediately
    - match:
        severity: critical
      receiver: critical
      continue: true

receivers:
{% if not _discord_enabled and not _telegram_enabled %}
  # No Discord webhook or Telegram bot configured — receivers are no-ops.
  - name: default
  - name: critical
{% else %}
  - name: default
{% if _discord_enabled %}
    discord_configs:
      - webhook_url: "{{ _discord_webhook }}"
        send_resolved: true
        title: >-
          [{{ '{{' }} .Status | toUpper {{ '}}' }}][{{ '{{' }} .CommonLabels.chain {{ '}}' }}]
          {{ '{{' }} .CommonAnnotations.summary {{ '}}' }}
        message: >-
          {{ '{{' }} range .Alerts {{ '}}' }}
          **Alert:** {{ '{{' }} .Annotations.summary {{ '}}' }}
          **Host:** {{ '{{' }} .Labels.instance {{ '}}' }}
          **Cohort:** {{ '{{' }} .Labels.cohort {{ '}}' }}
          **Provider:** {{ '{{' }} .Labels.provider {{ '}}' }}
          {{ '{{' }} end {{ '}}' }}
{% endif %}
{% if _telegram_enabled %}
    telegram_configs:
      - bot_token: "{{ _tg_token }}"
        chat_id: {{ _tg_chat_id }}
        send_resolved: true
        parse_mode: "HTML"
        message: >-
          [{{ '{{' }} .Status | toUpper {{ '}}' }}][{{ '{{' }} .CommonLabels.chain {{ '}}' }}]
          {{ '{{' }} .CommonAnnotations.summary {{ '}}' }}
          {{ '{{' }} range .Alerts {{ '}}' }}
          host={{ '{{' }} .Labels.instance {{ '}}' }}
          cohort={{ '{{' }} .Labels.cohort {{ '}}' }}
          {{ '{{' }} end {{ '}}' }}
{% endif %}

  - name: critical
{% if _discord_enabled %}
    discord_configs:
      - webhook_url: "{{ _discord_webhook }}"
        send_resolved: true
        title: >-
          🚨 CRITICAL — {{ '{{' }} .CommonAnnotations.summary {{ '}}' }}
        message: >-
          {{ '{{' }} range .Alerts {{ '}}' }}
          **Alert:** {{ '{{' }} .Annotations.summary {{ '}}' }}
          **Host:** {{ '{{' }} .Labels.instance {{ '}}' }}
          **Cohort:** {{ '{{' }} .Labels.cohort {{ '}}' }}
          {{ '{{' }} end {{ '}}' }}
{% endif %}
{% if _telegram_enabled %}
    telegram_configs:
      - bot_token: "{{ _tg_token }}"
        chat_id: {{ _tg_chat_id }}
        send_resolved: true
        parse_mode: "HTML"
        message: >-
          🚨 CRITICAL — {{ '{{' }} .CommonAnnotations.summary {{ '}}' }}
          {{ '{{' }} range .Alerts {{ '}}' }}
          host={{ '{{' }} .Labels.instance {{ '}}' }}
          cohort={{ '{{' }} .Labels.cohort {{ '}}' }}
          {{ '{{' }} end {{ '}}' }}
{% endif %}
{% endif %}

inhibit_rules:
  - source_match:
      severity: critical
    target_match:
      severity: warning
    equal: ["alertname", "instance"]
