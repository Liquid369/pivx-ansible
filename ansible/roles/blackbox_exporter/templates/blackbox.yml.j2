modules:
  # TCP connect probe — used to check PIVX P2P ports are open
  tcp_connect:
    prober: tcp
    timeout: 5s
    tcp:
      preferred_ip_protocol: "ip4"

  # TCP connect probe for IPv6 endpoints
  tcp_connect_ipv6:
    prober: tcp
    timeout: 5s
    tcp:
      preferred_ip_protocol: "ip6"

  # HTTP probe — used to check monitoring endpoints
  http_200:
    prober: http
    timeout: 5s
    http:
      valid_http_versions: ["HTTP/1.1", "HTTP/2.0"]
      valid_status_codes: [200]
      method: GET
      fail_if_ssl: false
      fail_if_not_ssl: false
