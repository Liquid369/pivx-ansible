# /etc/prometheus/prometheus.yml
# Generated by Ansible — {{ ansible_date_time.date }}
# Scrapes node_exporter from all fleet hosts, with full label enrichment.

global:
  scrape_interval:     {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_scrape_interval }}
  external_labels:
    chain:   "{{ chain }}"
    env:     "testnet6"

rule_files:
  - "/etc/prometheus/rules/*.yml"

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["localhost:{{ alertmanager_port }}"]

# ---------------------------------------------------------------------------
# Scrape configs
# ---------------------------------------------------------------------------

# node_exporter on all fleet hosts
scrape_configs:

  - job_name: "node_exporter"
    static_configs:
{% for host in groups['all'] %}
      - targets: ["{{ hostvars[host]['ansible_host'] }}:{{ node_exporter_port }}"]
        labels:
          instance:        "{{ host }}"
          host:            "{{ host }}"
          provider:        "{{ hostvars[host]['provider'] | default('unknown') }}"
          node_role:       "{{ hostvars[host]['node_role'] | default('unknown') }}"
          chaos_group:     "{{ hostvars[host]['chaos_group'] | default('unknown') }}"
          chain:           "{{ chain }}"
{% endfor %}

  # process-exporter on all fleet hosts; exposes pivxd/vector/tor process state.
  - job_name: "process_exporter"
    static_configs:
{% for host in groups['all'] %}
      - targets: ["{{ hostvars[host]['ansible_host'] }}:{{ process_exporter_port }}"]
        labels:
          instance:        "{{ host }}"
          host:            "{{ host }}"
          provider:        "{{ hostvars[host]['provider'] | default('unknown') }}"
          node_role:       "{{ hostvars[host]['node_role'] | default('unknown') }}"
          chaos_group:     "{{ hostvars[host]['chaos_group'] | default('unknown') }}"
          chain:           "{{ chain }}"
{% endfor %}

  # Self-monitoring of Prometheus
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:{{ prometheus_port }}"]
        labels:
          instance: "{{ monitoring_host }}"

  # Loki self-monitoring
  - job_name: "loki"
    static_configs:
      - targets: ["localhost:{{ loki_port }}"]
        labels:
          instance: "{{ monitoring_host }}"

  # Alertmanager self-monitoring
  - job_name: "alertmanager"
    static_configs:
      - targets: ["localhost:{{ alertmanager_port }}"]
        labels:
          instance: "{{ monitoring_host }}"
