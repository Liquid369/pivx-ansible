# Prometheus alerting rules — PIVX Testnet6
# Generated by Ansible. Covers all lifecycle phases:
#   - Node/host availability
#   - Bootstrap mining phase (Phase 2)
#   - PoS/staking phase (Phase 3)
#   - Masternode/quorum phase (Phase 4)
#
# NOTE: Rules referencing job="pivxd_exporter" are PLACEHOLDERS.
# A custom PIVX process/RPC exporter is needed for those.
# Until then they will always be "no data" and won't fire.
# node_exporter rules (cpu, disk, memory, up) are fully functional now.

groups:

  # ===========================================================================
  # HOST AVAILABILITY
  # ===========================================================================
  - name: host_availability
    interval: 30s
    rules:

      - alert: NodeDown
        expr: up{job="node_exporter"} == 0
        for: 2m
        labels:
          severity: critical
          chain: "{{ chain }}"
        annotations:
          summary: "Host {{ '{{' }} $labels.instance {{ '}}' }} is unreachable"
          description: >
            node_exporter on {{ '{{' }} $labels.instance {{ '}}' }}
            (provider={{ '{{' }} $labels.provider {{ '}}' }}) has been
            unreachable for more than 2 minutes.

      - alert: SeedNodeDown
        expr: up{job="node_exporter", node_role="seeder"} == 0
        for: 2m
        labels:
          severity: critical
          chain: "{{ chain }}"
        annotations:
          summary: "SEED NODE {{ '{{' }} $labels.instance {{ '}}' }} is down"
          description: >
            Seed node {{ '{{' }} $labels.instance {{ '}}' }} has been
            unreachable for >2 minutes. New nodes cannot bootstrap the chain.

      - alert: HighCPU
        expr: 100 - (avg by (instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 90
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "High CPU on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "CPU usage exceeds 90% for 10 minutes."

      - alert: HighCPUMiningNode
        # During bootstrap_mining, elevated CPU is expected. Raise threshold.
        expr: |
          100 - (avg by (instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 98
          and on(instance) node_meta_node_role{role="bootstrap_miner"} == 1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Miner CPU near 100% on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "Bootstrap miner CPU at near 100% — expected during active mining, but verify it hasn't stalled."

      - alert: DiskSpaceLow
        expr: |
          (node_filesystem_avail_bytes{mountpoint="/",fstype!="tmpfs"}
           / node_filesystem_size_bytes{mountpoint="/",fstype!="tmpfs"}) * 100 < 15
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Low disk on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "Root filesystem below 15% free. PIVX datadirs grow continuously."

      - alert: DiskSpaceCritical
        expr: |
          (node_filesystem_avail_bytes{mountpoint="/",fstype!="tmpfs"}
           / node_filesystem_size_bytes{mountpoint="/",fstype!="tmpfs"}) * 100 < 5
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "CRITICAL: Disk nearly full on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "Root filesystem below 5% free. Instances will crash-loop soon."

      - alert: MemoryLow
        expr: (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100 < 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Low memory on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "Less than 10% RAM available."

  # ===========================================================================
  # PIVX SERVICE STATE
  # Rules below require a custom PIVX exporter. Flagged as PLACEHOLDER.
  # ===========================================================================
  - name: pivx_service
    interval: 60s
    rules:

      # PLACEHOLDER: requires pivxd_exporter (see docs/OBSERVABILITY.md)
      - alert: PivxdInstanceDown
        expr: up{job="pivxd_exporter"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "PIVX instance {{ '{{' }} $labels.instance {{ '}}' }} is down"
          description: >
            pivxd instance {{ '{{' }} $labels.instance {{ '}}' }}
            (cohort={{ '{{' }} $labels.cohort {{ '}}' }},
             protocol={{ '{{' }} $labels.protocol_class {{ '}}' }})
            has been unreachable for >3 minutes.

      # PLACEHOLDER: chain height metric from custom exporter
      - alert: ChainHeightDiverged
        expr: |
          max(pivxd_block_height) - min(pivxd_block_height) > 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Chain height divergence across fleet"
          description: >
            There is >10 block difference between the highest and lowest block
            heights in the fleet. Possible stalled instance or network partition.

      # PLACEHOLDER: peer count from custom exporter
      - alert: PeerCountTooLow
        expr: pivxd_peer_count < {{ min_peer_count | default(2) }}
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Low peer count on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: >
            Instance {{ '{{' }} $labels.instance {{ '}}' }} has fewer than
            {{ min_peer_count | default(2) }} peers.

      - alert: AllTorInstancesDown
        expr: count(up{job="pivxd_exporter", cohort="tor"} == 0) == count(up{job="pivxd_exporter", cohort="tor"})
        for: 2m
        labels:
          severity: critical
          cohort: tor
        annotations:
          summary: "ALL Tor masternode instances are down"
          description: "The entire Tor cohort has gone offline. Quorum will degrade."

      - alert: AllIPv6InstancesDown
        expr: count(up{job="pivxd_exporter", cohort="ipv6"} == 0) == count(up{job="pivxd_exporter", cohort="ipv6"})
        for: 2m
        labels:
          severity: critical
          cohort: ipv6
        annotations:
          summary: "ALL IPv6 masternode instances are down"
          description: "The entire IPv6 cohort has gone offline. Quorum will degrade."

      - alert: ProviderMajorityDown
        expr: |
          count(up{job="pivxd_exporter"} == 0) by (provider)
          / count(up{job="pivxd_exporter"}) by (provider) > 0.5
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Majority of {{ '{{' }} $labels.provider {{ '}}' }} PIVX instances are down"
          description: >
            More than 50% of {{ '{{' }} $labels.provider {{ '}}' }} PIVX
            instances are unreachable. Potential provider-level outage.

  # ===========================================================================
  # BOOTSTRAP MINING PHASE (Phase 2)
  # ===========================================================================
  - name: bootstrap_mining
    interval: 60s
    rules:

      # PLACEHOLDER: requires custom miner exporter or process check
      - alert: BootstrapMinerDown
        expr: up{job="node_exporter", node_role="bootstrap_miner"} == 0
        for: 3m
        labels:
          severity: critical
          lifecycle_phase: bootstrap_mining
        annotations:
          summary: "Bootstrap miner {{ '{{' }} $labels.instance {{ '}}' }} is down"
          description: >
            A bootstrap miner has been unreachable for >3 minutes.
            Chain progression will slow or stop if all miners go down.

  # ===========================================================================
  # OBSERVABILITY STACK HEALTH
  # ===========================================================================
  - name: monitoring_stack
    interval: 60s
    rules:

      - alert: PrometheusDown
        expr: up{job="prometheus"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Prometheus itself is down"
          description: "Prometheus on tn6-infra01 is not scraping."

      - alert: LokiDown
        expr: up{job="loki"} == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Loki log aggregation is down"
          description: "Vector agents on fleet hosts cannot ship logs."

      - alert: AlertmanagerDown
        expr: up{job="alertmanager"} == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Alertmanager is down — alerts will not route"
          description: "Alertmanager on tn6-infra01 is not responding."


