# /etc/vector/vector.toml
# Generated by Ansible for host: {{ inventory_hostname }}
# Ships PIVX journal logs to Loki with full instance metadata baked in.
# Lifecycle phase: {{ lifecycle_phase }}
#
# Log query examples (Grafana Explore / LogQL):
#   All PIVX logs:         {job="pivxd"}
#   Tor cohort:            {job="pivxd", cohort="tor"}
#   Mining phase logs:     {job="pivxd", lifecycle_phase="bootstrap_mining"}
#   DKG errors:            {job="pivxd"} |~ "(?i)dkg.*error"
#   By host:               {job="pivxd", host="{{ inventory_hostname }}"}

[api]
enabled = true
address = "127.0.0.1:{{ vector_port }}"

# ---------------------------------------------------------------------------
# Sources
# ---------------------------------------------------------------------------

[sources.pivx_journal]
type = "journald"
include_units = [
{% for inst in pivx_instances %}
{% if inst.enabled | default(true) %}
  "pivxd@{{ inst.name }}.service",
{% endif %}
{% endfor %}
]

[sources.system_journal]
type = "journald"
include_units = [
  "sshd.service",
  "systemd-networkd.service",
  "tor.service",
]

# ---------------------------------------------------------------------------
# Transforms: enrich PIVX logs with instance + lifecycle metadata
# ---------------------------------------------------------------------------

[transforms.pivx_enrich]
type = "remap"
inputs = ["pivx_journal"]
source = '''
  # Strip "pivxd-" prefix from SyslogIdentifier to get bare instance name
  .instance = replace!(string!(.SYSLOG_IDENTIFIER), "pivxd-", "")

  # Static instance metadata map — baked at deploy time from host_vars.
  # Avoids runtime lookups. Re-run deploy-pivx when instances change.
  instance_meta = {
{% for inst in pivx_instances %}
{% if inst.enabled | default(true) %}
    "{{ inst.name }}": {
      "protocol_class": "{{ inst.protocol_class }}",
      "cohort": "{{ inst.cohort }}",
      "role": "{{ inst.role }}",
      "p2p_port": "{{ inst.p2p_port }}"
    },
{% endif %}
{% endfor %}
  }

  meta            = get(instance_meta, [.instance]) ?? {}
  .protocol_class = get(meta, ["protocol_class"]) ?? "unknown"
  .cohort         = get(meta, ["cohort"]) ?? "unknown"
  .role           = get(meta, ["role"]) ?? "unknown"

  # Host-level labels
  .host             = "{{ inventory_hostname }}"
  .provider         = "{{ provider }}"
  .chain            = "{{ chain }}"
  .lifecycle_phase  = "{{ lifecycle_phase }}"
'''

[transforms.system_enrich]
type = "remap"
inputs = ["system_journal"]
source = '''
  .host             = "{{ inventory_hostname }}"
  .provider         = "{{ provider }}"
  .chain            = "{{ chain }}"
  .lifecycle_phase  = "{{ lifecycle_phase }}"
  .job              = "system"
'''

# ---------------------------------------------------------------------------
# Sinks: ship to Loki
# ---------------------------------------------------------------------------

[sinks.loki_pivx]
type    = "loki"
inputs  = ["pivx_enrich"]
endpoint = "{{ loki_endpoint }}"
encoding.codec = "logfmt"

[sinks.loki_pivx.labels]
host             = "{{ '{{' }} host {{ '}}' }}"
instance         = "{{ '{{' }} instance {{ '}}' }}"
protocol_class   = "{{ '{{' }} protocol_class {{ '}}' }}"
cohort           = "{{ '{{' }} cohort {{ '}}' }}"
role             = "{{ '{{' }} role {{ '}}' }}"
provider         = "{{ '{{' }} provider {{ '}}' }}"
chain            = "{{ chain }}"
lifecycle_phase  = "{{ lifecycle_phase }}"
job              = "pivxd"

[sinks.loki_system]
type     = "loki"
inputs   = ["system_enrich"]
endpoint = "{{ loki_endpoint }}"
encoding.codec = "logfmt"

[sinks.loki_system.labels]
host            = "{{ '{{' }} host {{ '}}' }}"
provider        = "{{ '{{' }} provider {{ '}}' }}"
chain           = "{{ chain }}"
lifecycle_phase = "{{ lifecycle_phase }}"
job             = "system"


[api]
enabled = true
address = "127.0.0.1:{{ vector_port }}"

# ---------------------------------------------------------------------------
# Sources
# ---------------------------------------------------------------------------

# Scrape systemd journal for all pivxd@ instances
[sources.pivx_journal]
type = "journald"
include_units = [
{% for inst in pivx_instances %}
  "pivxd@{{ inst.name }}.service",
{% endfor %}
]

# Node-level system journal (optional — for OS-level events)
[sources.system_journal]
type = "journald"
include_units = ["sshd.service", "systemd-networkd.service"]

# ---------------------------------------------------------------------------
# Transforms: enrich PIVX logs with instance metadata
# ---------------------------------------------------------------------------

[transforms.pivx_enrich]
type = "remap"
inputs = ["pivx_journal"]
source = '''
  # Extract instance name from systemd unit identifier
  .instance = replace!(string!(.SYSLOG_IDENTIFIER), "pivxd-", "")

  # Map instance name to protocol/cohort/role using static lookup
  # This avoids a runtime lookup; the mapping is baked at deploy time.
  instance_meta = {
{% for inst in pivx_instances %}
    "{{ inst.name }}": {
      "protocol_class": "{{ inst.protocol_class }}",
      "cohort": "{{ inst.cohort }}",
      "role": "{{ inst.role }}"
    },
{% endfor %}
  }

  meta = get(instance_meta, [.instance]) ?? {}
  .protocol_class = get(meta, ["protocol_class"]) ?? "unknown"
  .cohort         = get(meta, ["cohort"]) ?? "unknown"
  .role           = get(meta, ["role"]) ?? "unknown"

  # Standard labels applied to all logs from this host
  .host     = "{{ inventory_hostname }}"
  .provider = "{{ provider }}"
  .chain    = "{{ chain }}"
'''

# ---------------------------------------------------------------------------
# Sinks: ship to Loki
# ---------------------------------------------------------------------------

[sinks.loki_pivx]
type = "loki"
inputs = ["pivx_enrich"]
endpoint = "{{ loki_endpoint }}"
encoding.codec = "logfmt"

[sinks.loki_pivx.labels]
host            = "{{ '{{' }} host {{ '}}' }}"
instance        = "{{ '{{' }} instance {{ '}}' }}"
protocol_class  = "{{ '{{' }} protocol_class {{ '}}' }}"
cohort          = "{{ '{{' }} cohort {{ '}}' }}"
role            = "{{ '{{' }} role {{ '}}' }}"
provider        = "{{ '{{' }} provider {{ '}}' }}"
chain           = "{{ chain }}"
job             = "pivxd"

[sinks.loki_system]
type = "loki"
inputs = ["system_journal"]
endpoint = "{{ loki_endpoint }}"
encoding.codec = "logfmt"

[sinks.loki_system.labels]
host     = "{{ inventory_hostname }}"
provider = "{{ provider }}"
chain    = "{{ chain }}"
job      = "system"
