# group_vars/all/vault.yml.example
#
# COPY THIS FILE to vault.yml and populate real values,
# then encrypt with: ansible-vault encrypt vault.yml
#
# Never commit the real vault.yml — it is .gitignore'd.

vault_pivx_rpc_password: "REPLACE_ME_STRONG_PASSWORD"
vault_grafana_admin_password: "REPLACE_ME"

# Alert notifications — Discord and/or Telegram (leave REPLACE_ME to disable)
vault_alertmanager_discord_webhook: "https://discord.com/api/webhooks/REPLACE_ME"
vault_alertmanager_telegram_bot_token: "REPLACE_ME"
vault_alertmanager_telegram_chat_id: "REPLACE_ME"

vault_ssh_deploy_key_passphrase: ""   # leave blank if key has no passphrase
